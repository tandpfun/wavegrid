# Copy to .env and fill in. The real .env is gitignored — its only secret is
# the cloud server IP. Both machines read this same format:
#
#   cp deploy/.env.example deploy/.env
#
# Consumed by:
#   deploy/load-env.sh        (mac/linux manual dev)
#   deploy/ecosystem.config.js + deploy/cloud.sh   (cloud server, PM2)
#   deploy/receiver.cmd       (pangolin / Windows receiver)

# ── Shared ───────────────────────────────────────────────────────────
# Address of the cloud server running the simulator. Everything else that
# needs a WebSocket URL is derived from this: ws://CLOUD_IP:SIM_PORT
CLOUD_IP=YOUR_SERVER_IP
SIM_PORT=3000

# Grid geometry — must match across simulator and receiver.
# NUM_CANNONS=49
# GRID_COLUMNS=7

# ── Cloud server only (simulator + ui) ───────────────────────────────
# AUTH_PASSWORD=
# NEXT_PUBLIC_SIMULATOR_URL=   # auto-derived from CLOUD_IP if left unset

# ── Pangolin / receiver only ─────────────────────────────────────────
# SIMULATOR_URL=               # auto-derived from CLOUD_IP if left unset
# RECEIVER_ALPHA=0.06
# FALLBACK_DELAY=3000
# DEBUG_OSC=1

# OSC output — pick ONE: a single BEYOND target, or a routing config file.
# BEYOND_HOST=127.0.0.1
# BEYOND_PORT=7001
# BEYOND_GRID_ORDER=row        # "row" or "column"

# Multi-target routing: generate deploy/routing.json with
#   node deploy/gen-config.js   (defaults the IPs below)
# then point the receiver at it.
# ROUTING_CONFIG=deploy/routing.json   # path (relative to repo root) to JSON routing file
# BEYOND_A_HOST=192.168.1.68   # default for gen-config.js (beyond-a machine)
# BEYOND_B_HOST=192.168.1.69   # default for gen-config.js (beyond-b machine)
