{
  "name": "wavegrid",
  "version": "0.0.1",
  "author": "Dan Lynch <pyramation@gmail.com>",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/constructive-io/Illuminate"
  },
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev": "pnpm --filter @wavegrid/simulator run dev",
    "dev:sim": "pnpm --filter @wavegrid/simulator run dev",
    "dev:receiver": "pnpm --filter wavegrid run dev",
    "dev:relay": "pnpm --filter @wavegrid/relay run dev",
    "dev:ui": "pnpm --filter @wavegrid/ui run dev",
    "dev:webgl": "pnpm --filter @wavegrid/webgl run dev",
    "gen:config": "node deploy/gen-config.js",
    "deps": "pnpm up -r -i -L"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "lerna": "^9.0.3",
    "makage": "^0.3.0",
    "pgsql-test": "^4.9.4",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
